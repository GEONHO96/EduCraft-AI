# ============================================================
# EduCraftAI Backend — 환경변수 예제
# ============================================================
# 이 파일은 실제 값이 들어가지 않은 템플릿이다.
# 복사해서 `.env.local`로 저장하고 실제 값을 채워서 사용하라.
# (`.env.local`은 .gitignore에 등록되어 있어야 한다)
#
# IntelliJ IDEA: Run Configuration > Environment variables
# 커맨드라인: `set KEY=value` (cmd) 또는 `export KEY=value` (bash)

# ── AI (Anthropic Claude) ────────────────────────────────────
# 키가 없으면 챗봇·AI 생성 기능이 오프라인 폴백 모드로 동작한다.
AI_API_KEY=

# ── JWT ──────────────────────────────────────────────────────
# 로컬에서는 application.yml의 기본값 사용 가능, 운영에선 반드시 설정.
# 최소 256비트(32자 이상) 랜덤 문자열 권장.
JWT_SECRET=

# ── 소셜 로그인 — Naver ──────────────────────────────────────
# https://developers.naver.com/apps/ 에서 발급
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── 소셜 로그인 — Kakao ──────────────────────────────────────
# https://developers.kakao.com/ 에서 발급
KAKAO_CLIENT_ID=

# ── 메일 (SMTP) ──────────────────────────────────────────────
# Gmail 사용 시: 2단계 인증 + 앱 비밀번호 발급 필요
MAIL_USERNAME=
MAIL_PASSWORD=
